{
  "_comment": "OpenCode Go: subscription models (paid). Requires payment method on the workspace.",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_SIMPLE": "1",
    "ANTHROPIC_BASE_URL": "http://localhost:8787/go",
    "ANTHROPIC_API_KEY": "REPLACE_WITH_YOUR_ZEN_WORKSPACE_KEY",
    "ANTHROPIC_AUTH_TOKEN": "REPLACE_WITH_YOUR_ZEN_WORKSPACE_KEY"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "dangerouslySkipPermissions": true
  },
  "model": "deepseek-v4-flash",
  "skipDangerousModePermissionPrompt": true
}
